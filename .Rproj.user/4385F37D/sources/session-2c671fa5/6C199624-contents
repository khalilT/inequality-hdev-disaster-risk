##### Tables S1, S2, S3
```{r event counts}

#1 count and percentage of event types
count_percent_disaster <- disasters_df %>% 
    mutate(disaster_type = factor(disaster_type,levels = c("Flood", "Storm", "Landslide", "Cold wave",
                                                          "Heat wave", "Wildfire", "Drought"))) %>% 
  group_by(disaster_type) %>% 
  tally() %>% 
  mutate(total = sum(n)) %>% 
  mutate(percentage = round((n / total) * 100,2)) %>% 
