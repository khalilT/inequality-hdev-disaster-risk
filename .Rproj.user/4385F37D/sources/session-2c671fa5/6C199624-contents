  rename(`Total population`=total_population, `Total affected`=total_affected, `Total mortality`=total_deaths, `Total GDP`=total_gdp, `Total damages`=total_damages) %>% 
  pivot_longer(`Total population`:`Total damages`) %>% 
  mutate(name = factor(name,levels=c("Total population","Total affected","Total mortality","Total GDP","Total damages"))) %>% 
  group_by(sHDI_category,name) %>% 
  summarise(sum_var = sum(value, na.rm = T)) %>% 
  ungroup() %>% 
