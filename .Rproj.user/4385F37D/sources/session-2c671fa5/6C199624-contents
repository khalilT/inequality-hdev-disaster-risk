#extract coefficients for 1990 and 2020
impact_coeffs <- data.frame()

#popexposure
for (group in unique(number_popexposure_data_all$sHDI_category)) {
  model <- rq(total_population ~ year, tau=0.5,data = number_popexposure_data_all%>% filter(sHDI_category == group))
  
  model_summ <- summary(model,se = "nid")

  model_df <- data.frame(val_1990 = number_popexposure_data_all%>% filter(sHDI_category == group & year == 1990) %>% pull(total_population),
            val_2020 = number_popexposure_data_all%>% filter(sHDI_category == group & year == 2020) %>% pull(total_population),
            sHDI_group = group,
            slope = model$coefficients[2],
            pvalue = model_summ$coefficients[2,4],
            npoints = length(model$residuals),
            impact = "popexposure")
  impact_coeffs = rbind(impact_coeffs, model_df)
}


