# count of sHDI/HDI mismatches
disasters_df %>% 
  mutate(sHDI_category = factor(sHDI_category, levels=c("Low sHDI","Medium sHDI","High sHDI","Very high sHDI"))) %>% 
  select(c(sHDI_category, natHDI_category)) %>% 
