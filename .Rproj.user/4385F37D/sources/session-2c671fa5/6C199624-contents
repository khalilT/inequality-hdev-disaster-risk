### I - Supplementary Tables

#### Methods
```{r missing data table}

impacts_df <- disasters_df %>% 
  select(total_affected, total_deaths, total_damages)

# Calculate the number of available data points (non-missing values) in each column
available_data <- colSums(!is.na(impacts_df))

# Calculate the percentage of missing data in each column
missing_percentage <- colMeans(is.na(impacts_df)) * 100

# Combine the counts and percentages into a single data frame
result <- rbind(available_data, missing_percentage)
result[1, ] <- as.integer(result[1, ])

# Add row names for clarity
rownames(result) <- c("Available Data", "Missing Data (%)")
result %>% xtable()

```



